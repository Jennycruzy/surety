# Required by hosted faucet and permissionless settlement server actions.
SURETY_DEPLOYER_SECRET=
TXLINE_API_TOKEN=

# Optional: dedicated devnet RPC to avoid public-endpoint 429s in a hosted deploy.
# Defaults to https://api.devnet.solana.com when unset.
SURETY_RPC_ENDPOINT=

# Optional: shared secret for the /api/keeper pre-warm endpoint. An external scheduler
# (e.g. cron-job.org) must send it as `Authorization: Bearer <secret>`. Unset = endpoint
# is disabled (fails closed).
KEEPER_TRIGGER_SECRET=

# Defaults preserve the audited France–Spain demo build.
NEXT_PUBLIC_SURETY_FIXTURE_ID=18237038
NEXT_PUBLIC_SURETY_FIXTURE_LABEL=France v Spain, semifinal

# Team names on the outcome buttons. Set per fixture so labels never contradict the match;
# unset falls back to neutral "Home team" / "Away team" wording.
NEXT_PUBLIC_SURETY_HOME_TEAM=France
NEXT_PUBLIC_SURETY_AWAY_TEAM=Spain
NEXT_PUBLIC_SURETY_VAULT=CDyQxhDHsaWYNBvjJgGPVFZdsBD3mC28VEX5DkCZkqEC
NEXT_PUBLIC_SURETY_ASSET_MINT=FiJfrnLoc2vZmjixZqCEBuWd8A5EuDaF9MZZhd96bpck
SURETY_ODDS_SNAPSHOT_FILE=phase0-18237038-odds-snapshot.raw.json

# Enables on-demand TxLINE fixture/odds proof synchronization and formula-v2 issuance.
SURETY_REQUIRE_VALIDATED_ODDS=0
